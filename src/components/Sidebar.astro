---
import SiteLinkButtons from './SiteLinkButtons.astro';
import { navItems } from '../data/navigation';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const visibleNav = navItems.filter((item) => item.visible);
---

<aside class="sidebar">
  <!-- Photo placeholder — TODO: replace src with /assets/images/photo.jpg once available -->
  <div class="sidebar-photo-placeholder">
    Photo
  </div>

  <p class="sidebar-title">Paul Platzer's personal research website</p>

  <SiteLinkButtons />

  <hr style="border:none; border-top:1px solid #ccc;" />

  <nav class="sidebar-nav" aria-label="Main navigation">
    {visibleNav.map((item) => {
      const isActive =
        item.href === '/'
          ? currentPath === '/'
          : currentPath.startsWith(item.href);
      return (
        <a href={item.href} class={isActive ? 'active' : undefined}>
          {item.label}
        </a>
      );
    })}
  </nav>
</aside>
