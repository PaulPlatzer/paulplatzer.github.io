---
const links = [
  { label: 'ORCID',          href: 'https://orcid.org/0000-0002-5562-2806' },
  { label: 'GitHub',         href: 'https://github.com/PaulPlatzer/' },
  { label: 'ResearchGate',   href: 'https://www.researchgate.net/profile/Paul-Platzer' },
  { label: 'Google Scholar', href: 'https://scholar.google.com/citations?user=9ugAMEEAAAAJ' },
];
---

<div class="sidebar-links">
  {links.map((link) => (
    <a
      class="sidebar-link-btn"
      href={link.href}
      target="_blank"
      rel="noopener noreferrer"
    >
      {link.label}
    </a>
  ))}
</div>
