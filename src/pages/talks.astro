---
import BaseLayout from '../layouts/BaseLayout.astro';
import { talks } from '../data/talks';

const typeLabel: Record<string, string> = {
  oral:     '[oral]',
  poster:   '[poster]',
  invited:  '[invited]',
  seminar:  '[seminar]',
  other:    '[other]',
};

const sorted = talks.slice().sort((a, b) => b.year - a.year || b.date.localeCompare(a.date));
---

<BaseLayout title="Talks" description="Paul Platzer — Talks">
  <h1>Talks</h1>

  <ul class="talk-list">
    {sorted.map((talk) => (
      <li class="talk-item">
        <div class="talk-title">
          {talk.slidesUrl
            ? <a href={talk.slidesUrl} target="_blank" rel="noopener noreferrer">{talk.title}</a>
            : talk.title
          }
          {talk.type && (
            <span class="talk-type">{typeLabel[talk.type] ?? `[${talk.type}]`}</span>
          )}
        </div>
        <div class="talk-venue">
          {talk.venue}{talk.location ? `, ${talk.location}` : ''}
        </div>
        <div class="talk-date">{talk.date}</div>
        {(talk.slidesUrl || talk.videoUrl || talk.abstractUrl || talk.eventUrl) && (
          <div class="talk-links">
            {talk.slidesUrl && (
              <a class="pub-link" href={talk.slidesUrl} target="_blank" rel="noopener noreferrer">
                Slides
              </a>
            )}
            {talk.videoUrl && (
              <a class="pub-link" href={talk.videoUrl} target="_blank" rel="noopener noreferrer">
                Video
              </a>
            )}
            {talk.abstractUrl && (
              <a class="pub-link" href={talk.abstractUrl} target="_blank" rel="noopener noreferrer">
                Abstract
              </a>
            )}
            {talk.eventUrl && (
              <a class="pub-link" href={talk.eventUrl} target="_blank" rel="noopener noreferrer">
                Event
              </a>
            )}
          </div>
        )}
      </li>
    ))}
  </ul>
</BaseLayout>
